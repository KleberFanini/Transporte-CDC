generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Perfil {
  admin
  visualizador
}

enum UsuarioStatus {
  ATIVO
  DESATIVADO
}

enum Plataforma {
  UBER
  NOVE_NOVE
}

enum corridaStatus{
  COMPLETA
  CANCELADA
  NAO_REALIZADA
  EM_ANDAMENTO
  DESCONHECIDO
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  perfil    Perfil     @default(visualizador)
  status      UsuarioStatus  @default(ATIVO)
  
  criadoEm DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model Corrida {
  id                  String    @id @default(uuid())
  idCorridaPlataforma String?   @unique
  plataforma          Plataforma
  status              corridaStatus @default(DESCONHECIDO)
  
  // Datas e horários
  dataSolicitacao     DateTime? @db.Date
  horaSolicitacao     String?
  dataChegada         DateTime? @db.Date
  horaChegada         String?
  
  // Informações da viagem
  servico             String?
  programa            String?
  grupo               String?
  
  // Funcionário
  nome                String?
  sobrenome           String?
  nomeCompleto        String?
  email               String? 
  
  // Detalhamento da despesa
  detalhamentoDespesa String?
  
  // Valores e métricas
  valorTotal          Decimal?  @db.Decimal(10,2)
  distanciaMetros     Int?
  duracaoMinutos      Int?
  
  // Endereços
  enderecoPartida     String?
  enderecoDestino     String?
  cidade              String?
  pais                String?
  
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  @@index([plataforma])
  @@index([status])
  @@index([dataSolicitacao])
  @@index([nomeCompleto])
}
